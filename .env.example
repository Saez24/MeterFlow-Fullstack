# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=meterflow
POSTGRES_USER=meterflow
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql+asyncpg://meterflow:changeme@postgres:5432/meterflow

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_use_at_least_32_random_characters_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=80
ALLOWED_ORIGINS=http://localhost

# ── Storage Backend: none | local | minio ────────────────────────────────────
STORAGE_BACKEND=none

# Only when STORAGE_BACKEND=local:
# LOCAL_STORAGE_PATH=/data/photos

# Only when STORAGE_BACKEND=minio:
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=meter-photos
# S3_REGION=us-east-1

# ── MinIO (only needed with --profile storage) ────────────────────────────────
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
